<p style="color: green"><%= notice %></p>

<% content_for :title, "Students" %>

<h1>Students</h1>

<div id="students">
  <% @students.each do |student| %>
      <div>
        <strong>Student name:</strong>
        <%= link_to student.student_name, student_path(student) %>
      </div>
  <% end %>
</div>

<%= link_to "New student", new_student_path %>
